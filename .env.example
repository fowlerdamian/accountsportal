# Supabase project credentials
# Get these from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Same value as anon key — used by Contractor Hub edge function calls
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Compliance (MyAudit) — separate Supabase project
VITE_COMPLIANCE_SUPABASE_URL=https://zvzejdepjbpceirclclq.supabase.co
VITE_COMPLIANCE_SUPABASE_ANON_KEY=your-compliance-anon-key-here

# Magic link redirect URL — set to the production domain on Vercel
# Falls back to window.location.origin in local dev if not set
VITE_SUPABASE_REDIRECT_URL=https://accounts.automotivegroup.com.au

# Cin7 Core API credentials (server-side only — no VITE_ prefix)
# Get these from: Cin7 Core → Settings → API → Add Application
# If not set, SO numbers display as plain text (graceful degradation)
CIN7_ACCOUNT_ID=your_cin7_account_id
CIN7_API_KEY=your_cin7_application_key

# ── Sales Support (Supabase Edge Function secrets — set via Supabase dashboard or CLI) ──────────────
# HubSpot private app token: HubSpot → Settings → Integrations → Private Apps
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token

# SerpAPI key for Google search/news queries: https://serpapi.com
SERPAPI_KEY=your_serpapi_key

# Google Places API key (enable Places API in Google Cloud Console)
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Anthropic API key for AI summaries and call reason generation
# (ANTHROPIC_API_KEY is already used by other edge functions if present)
ANTHROPIC_API_KEY=your_anthropic_api_key
